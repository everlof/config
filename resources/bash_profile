# ~/.bash_profile managed by the config repo.
# Put machine-specific secrets and project tokens in ~/.bash_profile.local.

export BASH_SILENCE_DEPRECATION_WARNING=1
export JAVA_HOME=$(/usr/libexec/java_home -v17 2>/dev/null || true)

export LANG=en_US.UTF-8
export LC_MONETARY=sv_SE.UTF-8
export LC_ALL=en_US.UTF-8
export LC_NUMERIC=sv_SE.UTF-8

export FORB_TARGET_CURRENCY=SEK
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"
export PATH="$HOME/.npm-global/bin:$PATH"
export PATH="$HOME/.elan/bin:$PATH"

if [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

if [ -r /opt/homebrew/opt/chruby/share/chruby/chruby.sh ]; then
  source /opt/homebrew/opt/chruby/share/chruby/chruby.sh
fi
if [ -r /opt/homebrew/opt/chruby/share/chruby/auto.sh ]; then
  source /opt/homebrew/opt/chruby/share/chruby/auto.sh
fi
if command -v chruby >/dev/null 2>&1; then
  chruby 3.3.1 2>/dev/null || true
fi

if [ -r /opt/homebrew/etc/profile.d/bash_completion.sh ]; then
  source /opt/homebrew/etc/profile.d/bash_completion.sh
fi

if [ -r "$HOME/.cargo/env" ]; then
  source "$HOME/.cargo/env"
fi

if [ -d /opt/homebrew/share/google-cloud-sdk/bin ]; then
  export PATH="/opt/homebrew/share/google-cloud-sdk/bin:$PATH"
fi

if [ -x /opt/homebrew/opt/curl/bin/curl ]; then
  export PATH="/opt/homebrew/opt/curl/bin:$PATH"
fi

if [ -r "$HOME/.config/broot/launcher/bash/br" ]; then
  source "$HOME/.config/broot/launcher/bash/br"
fi

alias title='fido jira title --issue'
alias title-current='fido jira title'
alias branch='fido jira branch --issue'
alias branch-current='fido jira branch'
alias grep='grep -a'
alias l='ls -l'
alias ll='ls -la'
alias claude="$HOME/.local/bin/claude"

function update_terminal_tab_name {
  echo -ne "\033]0;${PWD##*/}\007"
}

cd() {
  if [ "$1" = "§" ]; then
    builtin cd "$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
  else
    builtin cd "$@"
  fi
}

parse_git_branch() {
  local dirt_info branch
  dirt_info=$(git status --short 2>/dev/null)
  branch=$(git branch 2>/dev/null | sed -e '/^[^*]/d' -e 's/* \(.*\)/\1/')

  if [ ${#dirt_info} -ne 0 ]; then
    branch="${branch}~"
  fi

  if [ ${#branch} -gt 0 ]; then
    echo "$branch"
  fi
}

thumb() {
  if [ "$1" -eq 0 ]; then
    echo -en "\xf0\x9f\x91\x8d"
  else
    echo -en "\xf0\x9f\x91\x8e"
  fi
}

mr() {
  local currentBranch encodedBranch url
  currentBranch=$(git rev-parse --abbrev-ref HEAD)
  encodedBranch=$(curl -Gso /dev/null -w %{url_effective} --data-urlencode "" --get "http://example.com?b=${currentBranch}" | cut -d'?' -f 2 | cut -d'=' -f 2)
  url="http://10.1.2.92/festinasweden/mobilewatchapps/-/merge_requests/new?merge_request%5Bsource_branch%5D=${encodedBranch}"

  case "$(uname)" in
    Linux) xdg-open "$url" ;;
    Darwin) open "$url" ;;
    *) echo "Unsupported operating system." ;;
  esac
}

pbx() {
  find . -name project.pbxproj ! -path "*DerivedData*" ! -path "*Pods*" | head -n 1
}

mj() {
  if [ $# -eq 0 ]; then
    cd "$(command mj)"
  else
    command mj "$@"
  fi
}

function timer_start {
  timer=${timer:-$SECONDS}
}

function timer_stop {
  timer_show=$(($SECONDS - $timer))
  unset timer
}

trap 'timer_start' DEBUG
PROMPT_COMMAND=__prompt_command

__prompt_command() {
  local EXIT="$?"
  timer_stop

  local EXTRAS=""
  local BLACK="\033[90m"
  local RED="\033[91m"
  local GREEN="\033[92m"
  local WHITE="\033[97m"
  local RESET="\033[0m"
  local GIT_BRANCH OUTPUT

  GIT_BRANCH=$(parse_git_branch)
  if [ ${#GIT_BRANCH} -gt 0 ]; then
    if [[ $GIT_BRANCH =~ ~$ ]]; then
      OUTPUT=${RED}${GIT_BRANCH}$RESET
    else
      OUTPUT=${BLACK}${GIT_BRANCH}$RESET
    fi
    EXTRAS="${WHITE}git: ${OUTPUT}"
  fi

  if [ ${#VIRTUAL_ENV} -gt 0 ]; then
    if [ ${#EXTRAS} -gt 0 ]; then
      EXTRAS="${EXTRAS}${WHITE} | venv: ${BLACK}${VIRTUAL_ENV}$RESET"
    else
      EXTRAS="${WHITE}venv: ${BLACK}${VIRTUAL_ENV}$RESET"
    fi
  fi

  if [ ${#EXTRAS} -gt 0 ]; then
    PS1="$(thumb $EXIT)  \033[97m[last: ${timer_show}s]\033[00m \033[91m\D{%T}\033[00m ${WHITE}(${RESET}${EXTRAS}${WHITE})${RESET}\] \033[94m\w\033[00m\n$ "
  else
    PS1="$(thumb $EXIT)  \033[97m[last: ${timer_show}s]\033[00m \033[91m\D{%T}\033[00m \033[94m\w\033[00m\n$ "
  fi

  update_terminal_tab_name
}

if [ -n "${SSL_CERT_FILE:-}" ] && [ ! -f "$SSL_CERT_FILE" ]; then
  unset SSL_CERT_FILE
fi

if [ -r "$HOME/.bash_profile.local" ]; then
  source "$HOME/.bash_profile.local"
fi
