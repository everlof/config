#!/bin/sh

# Check if this is a Rust project (Cargo.toml exists in repo root)
if [ -f "Cargo.toml" ]; then
    echo "Rust project detected, running checks..."

    echo "Running cargo fmt --check..."
    cargo fmt --all -- --check
    if [ $? -ne 0 ]; then
        echo "❌ Formatting check failed. Run 'cargo fmt' to fix."
        exit 1
    fi

    echo "Running cargo clippy..."
    cargo clippy --workspace --all-targets -- -D warnings
    if [ $? -ne 0 ]; then
        echo "❌ Clippy check failed. Fix the warnings above."
        exit 1
    fi

    echo "✓ Rust checks passed!"
fi

# Run repo-specific pre-commit hook if it exists
if [ -x ".git/hooks/pre-commit.local" ]; then
    .git/hooks/pre-commit.local
fi
